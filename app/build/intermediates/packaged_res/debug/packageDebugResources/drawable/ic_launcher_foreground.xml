<?xml version="1.0" encoding="utf-8"?>
<!--
    Minimalist clock icon: white on black.

    A nearly-complete circle with a 30° gap at the 10:30 position (top-left),
    and a diamond marker sitting in that gap.

    Canvas: 108×108dp adaptive foreground. Safe zone: inner 72×72dp (center 54,54).
    Circle: center (54,54), radius 22dp.

    Gap geometry (30° gap centred at 315° / 10:30):
      Arc start  → (43.0, 35.0)  at 330° CW from 12 o'clock
      Gap centre → (38.4, 38.4)  at 315° CW from 12 o'clock
      Arc end    → (35.0, 43.0)  at 300° CW from 12 o'clock

    Diamond geometry (major half 7.0, minor half 3.5):
      Protrudes ~2.5dp beyond outer edge (26.5dp) and inner edge (17.5dp).
      Major axis along radial direction center→gap = (-1,-1)/√2.
      Tips:  top (33.4,33.4)  bottom (43.4,43.4)
      Waist: right (40.9,35.9)  left (35.9,40.9)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Clock ring — 330° arc, flat ends, gap at top-left -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="9"
        android:strokeLineCap="butt"
        android:pathData="M 43,35 A 22,22 0 1,1 35,43" />

    <!-- Diamond marker at the gap -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 33.4,33.4 L 40.9,35.9 L 43.4,43.4 L 35.9,40.9 Z" />

</vector>
