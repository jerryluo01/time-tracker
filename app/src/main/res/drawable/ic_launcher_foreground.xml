<?xml version="1.0" encoding="utf-8"?>
<!--
    Minimalist clock icon: 2 colors (black background + light gray).

    A nearly-complete circle with a 30° gap at the 10:30 position (top-left),
    and a diamond marker sitting in that gap — oriented so its major axis aligns
    with the ring's tangent direction at the gap (upper-right / lower-left).

    strokeLineCap="butt" → flat square ends on the ring, not rounded.

    Canvas: 108×108dp adaptive foreground. Safe zone: inner 72×72dp (center 54,54).
    Circle: center (54,54), radius 26dp.

    Gap geometry (30° gap centred at the 10:30 / 315° position):
      Arc start  → (41.0, 31.5)  at 330° CW from 12 o'clock (~11 o'clock)
      Gap centre → (35.6, 35.6)  at 315° CW from 12 o'clock (~10:30)
      Arc end    → (31.5, 41.0)  at 300° CW from 12 o'clock (~10 o'clock)

    Diamond geometry (~1.8:1 aspect ratio, top tip points to 10:30):
      Major axis along the radial direction center→gap = (-1,-1)/√2 (upper-left).
      Top tip points toward 10:30 (directly at the gap); bottom tip points inward.
      Tips:  top (32.4,32.4)  bottom (38.8,38.8)  — major half = 4.5dp
      Waist: right (37.4,33.8)  left (33.8,37.4)  — minor half = 2.5dp
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Clock ring — 330° arc, flat square line caps, gap at top-left -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#C0C0C0"
        android:strokeWidth="4.5"
        android:strokeLineCap="butt"
        android:pathData="M 41,31.5 A 26,26 0 1,1 31.5,41" />

    <!-- Diamond marker at the gap — elongated along the ring's tangent direction -->
    <path
        android:fillColor="#C0C0C0"
        android:pathData="M 32.4,32.4 L 37.4,33.8 L 38.8,38.8 L 33.8,37.4 Z" />

</vector>
