<?xml version="1.0" encoding="utf-8"?>
<!--
    Minimalist clock icon: white on black.

    A nearly-complete circle with a 30° gap at the top-left (225° SVG / 10:30 position),
    and a trapezoidal piece "exploded" outward from the gap — like a pie-chart slice
    that has been pushed away from the ring.

    Canvas: 108×108dp adaptive foreground. Safe zone: inner 72×72dp (center 54,54).
    Ring: center (54,54), radius 20dp, strokeWidth 9 → outer edge r=24.5, inner edge r=15.5.

    Gap geometry (30° centred at 225° SVG = NW / top-left):
      Arc start (CW) → 240° SVG → (44.0, 36.7)
      Arc end   (CW) → 210° SVG → (36.7, 44.0)
      Gap spans 210°–240° SVG (both on the top-left)

    Trapezoid = annular sector at the gap, exploded 4dp outward along 225°:
      Explosion vector: 4 × (cos225°, sin225°) = (-2.83, -2.83)
      A  outer@210° + offset = (30.0, 38.9)   ← top-left corner (longest edge A→B)
      B  outer@240° + offset = (38.9, 30.0)   ← top-right corner of piece
      C  inner@240° + offset = (43.4, 37.8)   ← bottom-right corner
      D  inner@210° + offset = (37.8, 43.4)   ← bottom-left corner
      Outer edge A→B is the longest side, positioned at the top-left of the icon.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Clock ring — 330° arc, gap at top-left, radius 20 -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="9"
        android:strokeLineCap="butt"
        android:pathData="M 44.0,36.7 A 20,20 0 1,1 36.7,44.0" />

    <!-- Exploded trapezoid — annular sector pushed 4dp outward from ring center -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 30.0,38.9 L 38.9,30.0 L 43.4,37.8 L 37.8,43.4 Z" />

</vector>
