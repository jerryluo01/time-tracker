<?xml version="1.0" encoding="utf-8"?>
<!--
    Timer app icon — adaptive icon foreground layer
    108×108dp canvas, 72×72dp safe zone (18dp margin each side)

    Ring: center (54,54), outer r=26dp, inner r=16.12dp (38% thickness)
    Ring gap: 41° centered at 222.5°; Wedge arc: 21.7° (narrower → space on each side)
    Wedge exploded 2.08dp outward along 222.5° axis (8% of R)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Black background -->
    <path
        android:fillColor="#000000"
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z" />

    <!--
        White ring (donut with 41° gap removed at ~10:30 position)
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M 42.2,30.83
            A 26,26 0 1,1 29.89,44.26
            L 39.05,47.96
            A 16.12,16.12 0 1,0 46.68,39.64
            Z" />

    <!--
        White exploded wedge — 21.7° arc, displaced 2.08dp toward upper-left
        Narrower than ring gap → empty space on each side
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M 30.33,38.96
            A 26,26 0 0,1 36.95,31.73
            L 42.85,39.66
            A 16.12,16.12 0 0,0 38.74,44.14
            Z" />

</vector>
