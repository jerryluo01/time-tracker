<?xml version="1.0" encoding="utf-8"?>
<!--
    Timer app icon — adaptive icon foreground layer
    108×108dp canvas, 72×72dp safe zone (18dp margin each side)

    Ring: center (54,54), outer r=34dp, inner r=21.76dp (36% thickness)
    Gap:  27° centered at 222.5° (≈10:30 on clock face, upper-left)
          gapStart=209°, gapEnd=236°
    Wedge exploded 6.12dp outward along 222.5° axis
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Black background -->
    <path
        android:fillColor="#000000"
        android:pathData="M0,0 L108,0 L108,108 L0,108 Z" />

    <!--
        White ring (donut with 27° wedge removed at ~10:30 position)
        Outer arc: clockwise 333° from gapEnd(236°) → gapStart(209°)
        Inner arc: counterclockwise 333° from gapStart(209°) → gapEnd(236°)
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M 34.99,25.81
            A 34,34 0 1,1 24.26,37.52
            L 34.97,43.45
            A 21.76,21.76 0 1,0 41.83,35.96
            Z" />

    <!--
        White exploded wedge — same 27° arc, displaced 6.12dp toward upper-left
        Outer arc: clockwise 27° from gapStart(209°) → gapEnd(236°)
        Inner arc: counterclockwise 27° from gapEnd(236°) → gapStart(209°)
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M 19.75,33.38
            A 34,34 0 0,1 30.48,21.68
            L 37.32,31.83
            A 21.76,21.76 0 0,0 30.46,39.32
            Z" />

</vector>
